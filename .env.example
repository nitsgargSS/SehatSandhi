# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it's already in .gitignore

# Supabase (get from supabase.com → Your Project → Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Admin panel credentials (change these before going live!)
VITE_ADMIN_EMAIL=admin@sehatsandhi.com
VITE_ADMIN_PASS=change_this_password

# WhatsApp Business number (with country code, no + or spaces)
# Update in src/types/index.ts → WA_NUMBER
